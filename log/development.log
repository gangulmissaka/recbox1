  [1m[36mRecipe Create (0.1ms)[0m  [1m[32mINSERT INTO "recipes" ("title", "description", "instructions", "is_public", "user_id", "created_at", "updated_at") VALUES (?, ?, ?, ?, ?, ?, ?)[0m  [["title", "Creamy Tomato Soup"], ["description", "A comforting and easy-to-make soup that's perfect for a chilly day."], ["instructions", "In a large pot, heat butter over medium heat\nAdd diced onions and cook until they are translucent\nAdd minced garlic and cook until fragrant\nAdd canned tomatoes (undrained), chicken broth, and sugar\nBring to a boil and then reduce heat and simmer for 15-20 minutes\nRemove from heat and use an immersion blender to puree the soup until it's smooth\nStir in heavy cream and salt to taste\nReturn soup to the stove and heat until it's warmed through\nServe creamy tomato soup with crusty bread or grilled cheese sandwiches"], ["is_public", 1], ["user_id", 5], ["created_at", "2026-04-30 02:27:40.067798"], ["updated_at", "2026-04-30 02:27:40.067798"]]
