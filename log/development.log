  [1m[36mRecipe Create (0.2ms)[0m  [1m[32mINSERT INTO "recipes" ("title", "description", "instructions", "is_public", "user_id", "created_at", "updated_at") VALUES (?, ?, ?, ?, ?, ?, ?)[0m  [["title", "Roasted Root Vegetables"], ["description", "A simple and delicious side dish that features a variety of colorful root vegetables."], ["instructions", "Preheat the oven to 400°F (200°C)\nWash and chop a variety of root vegetables (such as carrots, parsnips, sweet potatoes, and beets) into bite-sized pieces\nToss the vegetables with olive oil, salt, pepper, and any desired herbs or spices (such as thyme, rosemary, or cumin)\nSpread the vegetables out in a single layer on a baking sheet\nRoast the vegetables for 30-40 minutes, stirring occasionally, until they are tender and caramelized\nServe roasted root vegetables as a side dish to any meal"], ["is_public", 1], ["user_id", 6], ["created_at", "2026-04-30 02:27:40.076176"], ["updated_at", "2026-04-30 02:27:40.076176"]]
