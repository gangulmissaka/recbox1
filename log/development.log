  [1m[36mRecipe Create (0.1ms)[0m  [1m[32mINSERT INTO "recipes" ("title", "description", "instructions", "is_public", "user_id", "created_at", "updated_at") VALUES (?, ?, ?, ?, ?, ?, ?)[0m  [["title", "Beef and Broccoli Stir-Fry"], ["description", "A quick and easy Asian-inspired dish that's perfect for a weeknight dinner."], ["instructions", "In a small mixing bowl, whisk together soy sauce, brown sugar, cornstarch, and water\nThinly slice beef and toss with cornstarch until coated\nHeat vegetable oil in a wok or large skillet and cook beef until browned\nRemove beef and set aside\nIn the same wok, add sliced garlic and ginger and cook until fragrant\nAdd sliced onions and broccoli florets and cook until vegetables are tender\nReturn beef to the wok and stir in the soy sauce mixture\nCook until the sauce thickens\nServe beef and broccoli stir-fry over rice"], ["is_public", 1], ["user_id", 4], ["created_at", "2026-04-30 02:27:40.058253"], ["updated_at", "2026-04-30 02:27:40.058253"]]
