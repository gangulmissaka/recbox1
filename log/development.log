  [1m[36mRecipe Create (0.1ms)[0m  [1m[32mINSERT INTO "recipes" ("title", "description", "instructions", "is_public", "user_id", "created_at", "updated_at") VALUES (?, ?, ?, ?, ?, ?, ?)[0m  [["title", "Spaghetti and Meatballs"], ["description", "A classic Italian dish that's hearty and satisfying."], ["instructions", "Cook spaghetti according to package instructions\nIn a large mixing bowl, combine ground beef, breadcrumbs, minced garlic, egg, parmesan cheese, salt, and pepper\nRoll the mixture into golf-ball-sized meatballs\nHeat olive oil in a large skillet and cook meatballs until browned on all sides\nAdd tomato sauce and simmer for 15-20 minutes\nServe meatballs and sauce over spaghetti"], ["is_public", 1], ["user_id", 3], ["created_at", "2026-04-30 02:27:40.052410"], ["updated_at", "2026-04-30 02:27:40.052410"]]
