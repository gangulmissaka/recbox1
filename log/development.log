  [1m[36mRecipe Create (0.2ms)[0m  [1m[32mINSERT INTO "recipes" ("title", "description", "instructions", "is_public", "user_id", "created_at", "updated_at") VALUES (?, ?, ?, ?, ?, ?, ?)[0m  [["title", "Pancakes"], ["description", "A simple and delicious pancake recipe that's perfect for breakfast."], ["instructions", "In a large mixing bowl, whisk together the flour, sugar, baking powder, baking soda, and salt\n  In a separate bowl, whisk together the milk, egg, and melted butter\n  Gradually mix the wet ingredients into the dry ingredients\n  Heat a nonstick pan over medium heat\n  Pour 1/4 cup of batter onto the pan for each pancake\n  Cook until bubbles form on the surface, then flip and cook for an additional 1-2 minutes\n  Serve with syrup and butter"], ["is_public", 1], ["user_id", 1], ["created_at", "2026-04-30 02:27:40.044197"], ["updated_at", "2026-04-30 02:27:40.044197"]]
