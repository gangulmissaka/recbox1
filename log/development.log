  [1m[36mRecipe Create (0.1ms)[0m  [1m[32mINSERT INTO "recipes" ("title", "description", "instructions", "is_public", "user_id", "created_at", "updated_at") VALUES (?, ?, ?, ?, ?, ?, ?)[0m  [["title", "Mac and Cheese"], ["description", "A classic comfort food that's easy to make and always delicious."], ["instructions", "Preheat the oven to 375°F\n  Cook the macaroni according to the package directions\n  In a large saucepan, melt the butter over medium heat\n  Add the flour and whisk until smooth\n  Gradually whisk in the milk and bring to a boil\n  Reduce heat and simmer until the sauce thickens\n  Stir in the cheese until melted\n  Combine the macaroni and cheese sauce in a baking dish\n  Bake for 20-25 minutes or until bubbly"], ["is_public", 1], ["user_id", 2], ["created_at", "2026-04-30 02:27:40.047397"], ["updated_at", "2026-04-30 02:27:40.047397"]]
