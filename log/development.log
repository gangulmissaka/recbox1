  [1m[36mRecipe Create (1.7ms)[0m  [1m[32mINSERT INTO "recipes" ("title", "description", "instructions", "is_public", "user_id", "created_at", "updated_at") VALUES (?, ?, ?, ?, ?, ?, ?)[0m  [["title", "Chicken Parmesan"], ["description", "A classic Italian dish that features breaded and pan-fried chicken cutlets topped with tomato sauce and melted cheese."], ["instructions", "Preheat the oven to 375°F (190°C).\nPound chicken cutlets until they are about 1/4 inch thick\nSeason chicken cutlets with salt and pepper\nIn a shallow dish, whisk together eggs and milk\nIn another shallow dish, combine bread crumbs, Parmesan cheese, and Italian seasoning\nDredge chicken cutlets in the egg mixture and then in the bread crumb mixture, making sure they are evenly coated\nHeat vegetable oil in a large skillet over medium-high heat\nCook chicken cutlets until browned on both sides, about 3-4 minutes per side\nTransfer chicken cutlets to a baking dish and top each one with tomato sauce and shredded mozzarella cheese\nBake for 15-20 minutes, until the cheese is melted and bubbly\nServe chicken Parmesan with pasta or a side salad"], ["is_public", 1], ["user_id", 5], ["created_at", "2026-04-30 02:27:40.062660"], ["updated_at", "2026-04-30 02:27:40.062660"]]
