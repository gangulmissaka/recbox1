  [1m[36mRecipe Create (0.1ms)[0m  [1m[32mINSERT INTO "recipes" ("title", "description", "instructions", "is_public", "user_id", "created_at", "updated_at") VALUES (?, ?, ?, ?, ?, ?, ?)[0m  [["title", "Beef Stroganoff"], ["description", "A classic Russian dish that's easy to make and perfect for a hearty meal."], ["instructions", "Cook egg noodles according to package instructions\nHeat butter in a large skillet and cook sliced beef until browned on all sides\nRemove beef and set aside\nIn the same skillet, add onions and cook until softened\nAdd sliced mushrooms and cook until they release their moisture\nAdd flour and stir to coat the vegetables\nGradually stir in beef broth and bring to a boil\nReduce heat and simmer until the sauce thickens\nAdd sour cream and stir until smooth\nAdd the beef to the sauce and cook until heated through\nServe beef stroganoff over egg noodles"], ["is_public", 1], ["user_id", 4], ["created_at", "2026-04-30 02:27:40.055299"], ["updated_at", "2026-04-30 02:27:40.055299"]]
