  [1m[36mRecipe Create (0.1ms)[0m  [1m[32mINSERT INTO "recipes" ("title", "description", "instructions", "is_public", "user_id", "created_at", "updated_at") VALUES (?, ?, ?, ?, ?, ?, ?)[0m  [["title", "Chicken Alfredo"], ["description", "Creamy and rich, this pasta dish is a favorite for dinner parties or a cozy night in."], ["instructions", "Cook the fettuccine according to package instructions\nSeason chicken breasts with salt and pepper and cook in a pan with olive oil until browned on both sides\nRemove the chicken from the pan and set aside\nIn the same pan, add butter and minced garlic, and cook until fragrant\nAdd heavy cream and simmer until the sauce thickens\nStir in grated parmesan cheese until melted and smooth\nSlice the chicken and add it to the sauce\nServe the chicken alfredo over the fettuccine"], ["is_public", 1], ["user_id", 3], ["created_at", "2026-04-30 02:27:40.050436"], ["updated_at", "2026-04-30 02:27:40.050436"]]
