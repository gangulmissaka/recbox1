  [1m[36mRecipe Create (0.1ms)[0m  [1m[32mINSERT INTO "recipes" ("title", "description", "instructions", "is_public", "user_id", "created_at", "updated_at") VALUES (?, ?, ?, ?, ?, ?, ?)[0m  [["title", "Grilled Lemon Garlic Shrimp"], ["description", "A flavorful and healthy seafood dish that's perfect for a summer barbecue."], ["instructions", "In a small bowl, whisk together olive oil, lemon juice, minced garlic, salt, and pepper\nAdd peeled and deveined shrimp to the bowl and toss to coat\nCover the bowl with plastic wrap and marinate in the refrigerator for 30 minutes\nPreheat a grill to medium-high heat\nThread the shrimp onto skewers (if using wooden skewers, be sure to soak them in water for at least 30 minutes before using)\nGrill shrimp skewers for 2-3 minutes per side, until they are pink and opaque\nServe grilled lemon garlic shrimp with a green salad or grilled vegetables"], ["is_public", 1], ["user_id", 6], ["created_at", "2026-04-30 02:27:40.071951"], ["updated_at", "2026-04-30 02:27:40.071951"]]
